---
import { t } from "../utils/i18n";

const personalImageAlt = "Fabricio Rene Crespo Rossel"
const imagePath = "/Portfolio/pfp.png"
---

<section id="about-content" class="about-editorial">
  <div class="about-grid" aria-hidden="true"></div>
  <div class="about-grain" aria-hidden="true"></div>
  <div class="about-editorial__grid">
    <div class="about-editorial__text">
      <p id="about-typed-line" class="about-editorial__typed"></p>
      <p id="about-meta-line" class="about-editorial__meta">
        {t("about.meta.born")} // {t("about.meta.agePrefix")}<span id="about-age"></span> // {t("about.meta.location")}
      </p>
      <p class="about-editorial__paragraph" set:html={t('about.paragraph1')} />
      <p class="about-editorial__paragraph" set:html={t('about.paragraph2')} />
      <p class="about-editorial__paragraph" set:html={t('about.paragraph3')} />
      <p class="about-editorial__paragraph" set:html={t('about.paragraph4')} />
    </div>
    <div class="about-editorial__media">
      <img
        width="560"
        height="700"
        src={imagePath}
        alt={personalImageAlt}
        class="about-editorial__image"
      />
    </div>
  </div>
</section>

<style>
  .about-editorial {
    width: 100%;
    border-top: 1px solid rgba(0, 0, 0, 0.55);
    padding-top: 1rem;
    overflow: hidden;
    position: relative;
    isolation: isolate;
    background: #fff;
  }
  .about-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(0, 0, 0, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
    background-size: 36px 36px;
    z-index: 0;
  }
  .about-grain {
    position: absolute;
    inset: 0;
    opacity: 0.045;
    z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }
  .about-editorial__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
    gap: 1.1rem;
    align-items: stretch;
    min-height: 68vh;
    position: relative;
    z-index: 2;
  }
  .about-editorial__text {
    padding: 0.3rem 0.3rem 0.8rem 0.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    animation: aboutReveal 420ms ease both;
  }
  .about-editorial__typed {
    margin: 0;
    font-family: "Arial Black", "Inter", sans-serif;
    font-size: clamp(1.35rem, 2.5vw, 2.2rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.02;
    min-height: 2.1em;
    white-space: normal;
    overflow-wrap: anywhere;
    max-width: 30ch;
    border-right: none;
  }
  .about-editorial__meta {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .about-editorial__paragraph {
    margin: 0;
    font-size: clamp(0.96rem, 1.18vw, 1.07rem);
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.76);
    max-width: 80ch;
    animation: aboutReveal 520ms ease both;
  }
  .about-editorial__media {
    border-left: 1px solid rgba(0, 0, 0, 0.28);
    padding-left: 0.85rem;
    display: flex;
    align-items: stretch;
    justify-content: center;
    animation: aboutReveal 560ms ease both;
  }
  .about-editorial__image {
    width: min(82%, 430px);
    height: auto;
    max-height: 58vh;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06);
    border: 1px solid #111;
    box-shadow: 12px 12px 0 rgba(0, 0, 0, 0.24);
    transition: transform 260ms ease, box-shadow 260ms ease;
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .about-editorial__image:hover {
      transform: translate(-5px, -5px);
      box-shadow: 16px 16px 0 rgba(0, 0, 0, 0.28);
      animation: aboutVhsFlicker 420ms steps(2, end) infinite;
    }

    :global(html.dark) .about-editorial__image:hover {
      box-shadow: 16px 16px 0 rgba(255, 255, 255, 0.28);
    }
  }

  @keyframes aboutVhsFlicker {
    0% { filter: grayscale(1) contrast(1.06); }
    35% { filter: grayscale(1) contrast(1.18) brightness(0.95); }
    55% { filter: grayscale(1) contrast(1.03) brightness(1.04); }
    100% { filter: grayscale(1) contrast(1.06); }
  }
  :global(html.dark) .about-editorial {
    border-color: rgba(255, 255, 255, 0.45);
    background: #000;
  }
  :global(html.dark) .about-grid {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
  }
  :global(html.dark) .about-editorial__paragraph { color: rgba(255, 255, 255, 0.78); }
  :global(html.dark) .about-editorial__media { border-color: rgba(255, 255, 255, 0.24); }
  :global(html.dark) .about-editorial__image {
    border-color: rgba(255, 255, 255, 0.75);
    box-shadow: 12px 12px 0 rgba(255, 255, 255, 0.25);
    filter: grayscale(1) contrast(1.1) brightness(0.9);
  }
  @keyframes aboutReveal {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    @keyframes aboutReveal {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .about-editorial__image {
      transition: none;
    }

    .about-editorial__image:hover {
      transform: none;
    }
  }
  @media (max-width: 640px) {
    .about-editorial__typed {
      min-height: 0;
      line-height: 1.05;
      font-size: clamp(1rem, 4.2vw, 1.5rem);
      max-width: 100%;
    }
  }

  @media (max-width: 980px) {
    .about-editorial__grid {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .about-editorial__media {
      border-left: none;
      border-top: 1px solid rgba(0, 0, 0, 0.28);
      padding-left: 0;
      padding-top: 0.85rem;
      order: -1;
    }
    :global(html.dark) .about-editorial__media { border-color: rgba(255, 255, 255, 0.24); }
    .about-editorial__image {
      width: min(72%, 320px);
      max-height: 45vh;
      box-shadow: 9px 9px 0 rgba(0, 0, 0, 0.2);
    }
  }
</style>

<script>
  import { t } from "../utils/i18n";

  const calculateAge = (year: number, month: number, day: number) => {
    const today = new Date();
    let age = today.getFullYear() - year;
    const monthDiff = today.getMonth() + 1 - month;
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < day)) age -= 1;
    return age;
  };

  const typeLine = (text: string) => {
    const el = document.getElementById("about-typed-line");
    if (!(el instanceof HTMLElement)) return;
    el.textContent = "";
    let i = 0;
    const interval = window.setInterval(() => {
      i += 1;
      el.textContent = text.slice(0, i);
      if (i >= text.length) window.clearInterval(interval);
    }, 34);
  };

  const updateAboutText = () => {
    const aboutRoot = document.querySelector("#about-content");
    const paragraphs = aboutRoot?.querySelectorAll(".about-editorial__paragraph");
    const metaLine = document.getElementById("about-meta-line");
    const ageEl = document.getElementById("about-age");
    if (ageEl) ageEl.textContent = String(calculateAge(2002, 6, 4));
    if (metaLine) {
      metaLine.innerHTML = `${t("about.meta.born")} // ${t("about.meta.agePrefix")}<span id="about-age">${calculateAge(2002, 6, 4)}</span> // ${t("about.meta.location")}`;
    }
    const typedText = `${t("about.title")} // ${t("about.roles.webDeveloper")} // ${t("about.roles.softwareEngineer")}`;
    typeLine(typedText.toUpperCase());
    paragraphs?.forEach((p, index) => {
      p.innerHTML = t(`about.paragraph${index + 1}`);
    });
  };

  window.addEventListener('storage', (e) => {
    if (e.key === 'language') {
      updateAboutText();
    }
  });
  window.addEventListener("language-change", updateAboutText);

  document.addEventListener('astro:page-load', () => {
    updateAboutText();
  });
</script>
