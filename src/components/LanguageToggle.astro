---
import { t } from "../utils/i18n"

const LANGUAGES = ["Español", "English"] as const

const getCurrentLanguage = () => {
  if (typeof localStorage !== "undefined") {
    return localStorage.getItem("language") ?? "Español"
  }
  return "Español"
}
---

<div class="language-toggle-root relative">
  <button
    type="button"
    class="js-lang-toggle-btn toggle-shell appearance-none flex items-center justify-center border border-black bg-white px-2 py-1 font-mono text-[11px] font-bold uppercase text-black transition hover:bg-black hover:text-white dark:border-white dark:bg-black dark:text-white dark:hover:bg-white dark:hover:text-black"
  >
    <span class="sr-only">{t("header.chooseLanguage")}</span>
    <span class="language-toggle-icon size-5 transition-all">
      {getCurrentLanguage() === "Español" ? "ES" : "EN"}
    </span>
  </button>
  <div
    class="js-lang-menu absolute right-0 top-[calc(100%+8px)] z-[90] hidden min-w-[9rem] border border-black bg-white p-1 text-sm text-black shadow-[0_3px_0_0_#000] dark:border-white dark:bg-black dark:text-white dark:shadow-[0_3px_0_0_#fff]"
  >
    <ul>
      {
        LANGUAGES.map((language) => (
          <li>
            <button
              type="button"
              class="js-lang-option block w-full cursor-pointer px-2 py-1.5 text-left uppercase hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black"
              data-language={language}
            >
              {language}
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  const dispatchLanguage = (language: string) => {
    const previous = localStorage.getItem("language");
    localStorage.setItem("language", language);
    window.dispatchEvent(new CustomEvent("language-change", { detail: { language } }));
    window.dispatchEvent(
      new StorageEvent("storage", {
        key: "language",
        newValue: language,
        oldValue: previous,
        storageArea: localStorage,
      }),
    );
    document.querySelectorAll(".language-toggle-icon").forEach((icon) => {
      icon.textContent = language === "Español" ? "ES" : "EN";
    });
  };

  const closeAllMenus = () => {
    document.querySelectorAll(".js-lang-menu").forEach((menu) => menu.classList.remove("open"));
  };

  let languageToggleReady = false;

  const setupLanguageToggle = () => {
    if (languageToggleReady) return;
    languageToggleReady = true;

    document.addEventListener("click", (event) => {
      const raw = event.target;
      const base =
        raw instanceof Element ? raw : raw instanceof Node ? (raw.parentElement ?? null) : null;
      if (!base) return;

      const toggleBtn = base.closest(".js-lang-toggle-btn");
      const optionBtn = base.closest(".js-lang-option");

      if (toggleBtn) {
        event.stopPropagation();
        const root = toggleBtn.closest(".language-toggle-root");
        const menu = root?.querySelector(".js-lang-menu");
        if (menu) {
          const willOpen = !menu.classList.contains("open");
          closeAllMenus();
          if (willOpen) menu.classList.add("open");
        }
        return;
      }

      if (optionBtn) {
        event.stopPropagation();
        const lang = optionBtn.getAttribute("data-language")?.trim();
        if (lang === "Español" || lang === "English") {
          dispatchLanguage(lang);
        }
        closeAllMenus();
        return;
      }

      closeAllMenus();
    });

    const syncIcons = () => {
      const lang = localStorage.getItem("language") ?? "Español";
      document.querySelectorAll(".language-toggle-icon").forEach((icon) => {
        icon.textContent = lang === "Español" ? "ES" : "EN";
      });
    };

    document.addEventListener("astro:page-load", syncIcons);
    syncIcons();
  };

  setupLanguageToggle();
</script>

<style>
  .js-lang-menu.open {
    display: block;
    transform-origin: top right;
    animation: scale-up-center 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  .toggle-shell {
    min-width: 46px;
    min-height: 34px;
    line-height: 1;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.8);
      opacity: 0;
    }

    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  @media (max-width: 768px) {
    .js-lang-menu {
      right: 0;
      left: auto;
      min-width: 8rem;
    }
  }
</style>
