---
import { t } from "../utils/i18n";

type ProjectRow = {
  key: string;
  title: string;
  description: string;
  link?: string;
  stackKey: string;
  sectorKey: string;
  statusKey: string;
  caseId: string;
};

const PROJECTS: ProjectRow[] = [
  { key: "grb", title: t("projects.items.grb.title"), description: t("projects.items.grb.description"), link: "https://www.grb-group.com/en/", stackKey: "astroTailwind", sectorKey: "infrastructureLogistics", statusKey: "active", caseId: "CASE_ID: 449-G" },
  { key: "profunded", title: t("projects.items.profunded.title"), description: t("projects.items.profunded.description"), link: "https://profunded.com/", stackKey: "nextjs", sectorKey: "fintechTrading", statusKey: "active", caseId: "CASE_ID: 144-P" },
  { key: "rebornrental", title: t("projects.items.rebornrental.title"), description: t("projects.items.rebornrental.description"), link: "https://rebornrental.com/", stackKey: "laravelBlade", sectorKey: "constructionRental", statusKey: "closed", caseId: "CASE_ID: 112-A" },
  { key: "reborn", title: t("projects.items.reborn.title"), description: t("projects.items.reborn.description"), link: "https://www.reborndevelopments.com/", stackKey: "nextLaravel", sectorKey: "bioDigitalSystems", statusKey: "ongoing", caseId: "CASE_ID: 009-R" },
  { key: "rebornhost", title: t("projects.items.rebornhost.title"), description: t("projects.items.rebornhost.description"), link: "https://www.rebornhost.com/index.html", stackKey: "htmlCss", sectorKey: "propertyOperations", statusKey: "active", caseId: "CASE_ID: 223-H" },
  { key: "eipet", title: t("projects.items.eipet.title"), description: t("projects.items.eipet.description"), link: "https://eipet-delta.vercel.app/", stackKey: "astroFirebase", sectorKey: "ecommerceSystem", statusKey: "active", caseId: "CASE_ID: 615-E" },
  { key: "hydraulics", title: t("projects.items.hydraulics.title"), description: t("projects.items.hydraulics.description"), link: "https://hydraylics-system.vercel.app/", stackKey: "astroFirebase", sectorKey: "heavyEquipmentServices", statusKey: "active", caseId: "CASE_ID: 781-H" },
];

---

<section class="project-files">
  <div class="project-files__grid">
    {PROJECTS.map((project) => (
      <article class="file-card project-entry">
        <div class="file-card__tab">{project.caseId}</div>
        <a
          href={project.link ?? "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="file-card__trigger"
        >
          <div class="file-card__inner">
            <h4 class="project-title">{project.title}</h4>
            <p class="file-card__sector">{t(`projects.meta.sector.${project.sectorKey}`)}</p>
            <div class="file-card__row"><span class="project-label-status">{t("projects.meta.labels.status")}</span><span class="project-value-status">{t(`projects.meta.status.${project.statusKey}`)}</span></div>
            <div class="file-card__row"><span class="project-label-stack">{t("projects.meta.labels.stack")}</span><span class="project-value-stack">{t(`projects.meta.stack.${project.stackKey}`)}</span></div>
            <footer class="file-card__footer"><span class="project-open-label">{t("projects.meta.labels.openFile")}</span><span aria-hidden="true">→</span></footer>
          </div>
          <div class="file-card__preview" aria-hidden="true">
            <div class="file-card__preview-overlay">
              <p class="file-card__preview-label">{t("projects.meta.labels.previewDescription")}</p>
              <p class="file-card__preview-description project-description">{project.description}</p>
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  .project-files {
    border-top: 1px solid rgba(0, 0, 0, 0.55);
    padding-top: 1.1rem;
    overflow-x: clip;
  }
  .project-files__grid { display: grid; gap: 1.4rem; grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .file-card {
    position: relative;
    background: #f7f7f7;
    border: 1px solid #111;
    box-shadow: 8px 8px 0 #111;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .file-card__trigger { display: block; width: 100%; color: inherit; text-decoration: none; position: relative; }
  .file-card__tab { position: absolute; top: -1px; left: -1px; background: #111; color: #fff; font-family: "JetBrains Mono", monospace; font-size: 9px; letter-spacing: 0.13em; text-transform: uppercase; padding: 0.32rem 0.8rem 0.32rem 0.62rem; clip-path: polygon(0 0, 92% 0, 100% 100%, 0 100%); }
  .file-card__inner { min-height: 300px; padding: 1.8rem 1rem 0.95rem; display: flex; flex-direction: column; transition: transform 180ms ease, opacity 180ms ease; }
  .project-title { margin: 0; font-family: "Times New Roman", serif; font-size: clamp(1.8rem, 2.2vw, 2.35rem); line-height: 0.95; text-transform: uppercase; letter-spacing: -0.015em; }
  .file-card__sector { margin: 0.6rem 0 1rem; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(0, 0, 0, 0.65); padding-bottom: 0.55rem; border-bottom: 1px solid rgba(0, 0, 0, 0.35); }
  .file-card__row { display: flex; justify-content: space-between; gap: 0.6rem; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(0, 0, 0, 0.78); padding: 0.55rem 0; border-bottom: 1px solid rgba(0, 0, 0, 0.14); }
  .file-card__footer { margin-top: auto; padding-top: 0.7rem; border-top: 2px solid rgba(0, 0, 0, 0.7); display: flex; justify-content: space-between; align-items: center; font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; }
  .file-card__footer span { font-size: 1.4rem; line-height: 1; }
  .file-card__preview { position: absolute; inset: 0; opacity: 0; transform: translateY(8px); transition: opacity 180ms ease, transform 180ms ease; pointer-events: none; }
  .file-card__preview-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.68) 60%, rgba(0, 0, 0, 0.52) 100%),
      repeating-linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.05) 0 1px,
        transparent 1px 20px
      );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
  }
  .file-card__preview-label { margin: 0 0 0.5rem; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255, 255, 255, 0.86); }
  .file-card__preview-description { margin: 0; font-size: clamp(0.92rem, 1.2vw, 1rem); line-height: 1.45; color: #fff; max-height: 8.3em; overflow: hidden; }
  .file-card__trigger:hover .file-card__preview,
  .file-card__trigger:focus-visible .file-card__preview,
  .file-card__trigger:focus .file-card__preview { opacity: 1; transform: translateY(0); }
  .file-card__trigger:hover .file-card__inner,
  .file-card__trigger:focus-visible .file-card__inner,
  .file-card__trigger:focus .file-card__inner { opacity: 0.08; transform: scale(0.99); }
  .file-card__trigger:focus-visible { outline: 1px dashed #111; outline-offset: 4px; }
  :global(html.dark) .project-files { border-color: rgba(255, 255, 255, 0.45); }
  :global(html.dark) .file-card { background: #0b0b0b; border-color: rgba(255, 255, 255, 0.72); box-shadow: 8px 8px 0 rgba(255, 255, 255, 0.7); }
  :global(html.dark) .file-card__tab { background: #fff; color: #000; }
  :global(html.dark) .file-card__sector, :global(html.dark) .file-card__row { color: rgba(255, 255, 255, 0.75); border-color: rgba(255, 255, 255, 0.24); }
  :global(html.dark) .file-card__footer { border-color: rgba(255, 255, 255, 0.8); }
  :global(html.dark) .file-card__trigger:focus-visible { outline-color: rgba(255, 255, 255, 0.75); }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .file-card:has(.file-card__trigger:hover) {
      transform: translate(-4px, -4px);
      box-shadow: 12px 12px 0 #111;
    }
    :global(html.dark) .file-card:has(.file-card__trigger:hover) {
      box-shadow: 12px 12px 0 rgba(255, 255, 255, 0.72);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .file-card__footer span:last-child {
      display: inline-block;
      transition: transform 180ms ease;
    }
    .file-card__trigger:hover .file-card__footer span:last-child {
      transform: translateX(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .file-card {
      transition: none;
    }
  }

  @media (max-width: 1100px) { .project-files__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 700px) { .project-files__grid { grid-template-columns: 1fr; gap: 1rem; } .file-card__inner { min-height: 280px; } .project-title { font-size: clamp(1.45rem, 7.2vw, 2rem); } .file-card__preview-description { max-height: none; } .file-card__trigger:active .file-card__preview { opacity: 1; transform: translateY(0); } }
</style>

<script>
  import { t } from "../utils/i18n";
  const ITEMS = ["grb", "profunded", "rebornrental", "reborn", "rebornhost", "eipet", "hydraulics"];
  const SECTORS = ["infrastructureLogistics", "fintechTrading", "constructionRental", "bioDigitalSystems", "propertyOperations", "ecommerceSystem", "heavyEquipmentServices"];
  const STATUSES = ["active", "active", "closed", "ongoing", "active", "active", "active"];
  const STACKS = ["astroTailwind", "nextjs", "laravelBlade", "nextLaravel", "htmlCss", "astroFirebase", "astroFirebase"];
  const updateProjectsText = () => {
    const rows = document.querySelectorAll(".project-entry");
    rows.forEach((row, index) => {
      const title = row.querySelector(".project-title");
      const description = row.querySelector(".project-description");
      const sector = row.querySelector(".file-card__sector");
      const statusLabel = row.querySelector(".project-label-status");
      const statusValue = row.querySelector(".project-value-status");
      const stackLabel = row.querySelector(".project-label-stack");
      const stackValue = row.querySelector(".project-value-stack");
      const openLabel = row.querySelector(".project-open-label");
      const previewLabel = row.querySelector(".file-card__preview-label");
      if (title) title.textContent = t(`projects.items.${ITEMS[index]}.title`);
      if (description) description.textContent = t(`projects.items.${ITEMS[index]}.description`);
      if (sector && SECTORS[index]) sector.textContent = t(`projects.meta.sector.${SECTORS[index]}`);
      if (statusLabel) statusLabel.textContent = t("projects.meta.labels.status");
      if (statusValue && STATUSES[index]) statusValue.textContent = t(`projects.meta.status.${STATUSES[index]}`);
      if (stackLabel) stackLabel.textContent = t("projects.meta.labels.stack");
      if (stackValue && STACKS[index]) stackValue.textContent = t(`projects.meta.stack.${STACKS[index]}`);
      if (openLabel) openLabel.textContent = t("projects.meta.labels.openFile");
      if (previewLabel) previewLabel.textContent = t("projects.meta.labels.previewDescription");
    });
  };

  window.addEventListener("storage", (e) => { if (e.key === "language") updateProjectsText(); });
  window.addEventListener("language-change", updateProjectsText);
  document.addEventListener("astro:page-load", updateProjectsText);
</script>
