---
import { t } from "../utils/i18n";

type AchievementRow = {
  key: string;
  title: string;
  description: string;
  pdf: string;
  code: string;
};

const achievements: AchievementRow[] = [
  { key: "recommendation", title: t("achievements.items.recommendation.title"), description: t("achievements.items.recommendation.description"), pdf: "/Portfolio/Carta Ing Rene.pdf", code: "LOG_01" },
  { key: "goit", title: t("achievements.items.goit.title"), description: t("achievements.items.goit.description"), pdf: "/Portfolio/GoITRecommendation.pdf", code: "LOG_02" },
  { key: "sedes", title: t("achievements.items.sedes.title"), description: t("achievements.items.sedes.description"), pdf: "/Portfolio/certificates/sedes-certificate.pdf", code: "LOG_03" },
  { key: "tracto", title: t("achievements.items.tracto.title"), description: t("achievements.items.tracto.description"), pdf: "/Portfolio/certificates/tractocamiones-certificate.pdf", code: "LOG_04" },
];
---

<section class="files-scene">
  {achievements.map((achievement, index) => (
    <article class="floating-file" data-index={index} data-key={achievement.key}>
      <a href={achievement.pdf} target="_blank" rel="noopener noreferrer" class="floating-file__sheet">
        <div class="floating-file__preview" aria-hidden="true">
          <div class="floating-file__preview-paper">
            <p class="floating-file__preview-code">{achievement.code}</p>
            <h4 class="floating-file__preview-title">{achievement.title}</h4>
            <div class="floating-file__preview-lines">
              <span></span><span></span><span></span><span></span><span></span>
            </div>
            <p class="floating-file__preview-mark">PDF // OPEN FILE</p>
          </div>
        </div>
        <footer class="floating-file__meta">
          <span>{achievement.code}</span>
          <span class="floating-file__title">{achievement.title}</span>
        </footer>
      </a>
    </article>
  ))}
</section>

<style>
  .files-scene {
    margin-inline: calc(50% - 50vw + 1rem);
    width: calc(100vw - 2rem);
    min-height: 76vh;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
    align-items: center;
    perspective: 1800px;
    padding: 1rem 0.4rem 2rem;
  }
  .floating-file { display: flex; justify-content: center; }

  .floating-file__sheet {
    width: min(100%, 320px);
    aspect-ratio: 8.5 / 11;
    display: flex;
    flex-direction: column;
    border: 1px solid #111;
    background: #fff;
    color: inherit;
    text-decoration: none;
    box-shadow: 14px 16px 0 rgba(0, 0, 0, 0.24);
    overflow: hidden;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }
  .floating-file__sheet { transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg); }

  .floating-file__preview {
    width: 100%;
    height: 100%;
    padding: 0.7rem;
    background:
      linear-gradient(135deg, rgba(0, 0, 0, 0.06), transparent 42%),
      repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.04) 0 1px,
        transparent 1px 26px
      ),
      #f2f2f2;
    pointer-events: none;
    overflow: hidden;
  }
  .floating-file__preview-paper {
    height: 100%;
    border: 1px solid rgba(0, 0, 0, 0.3);
    background: rgba(255, 255, 255, 0.95);
    padding: 0.8rem 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .floating-file__preview-code {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.8;
  }
  .floating-file__preview h4 {
    margin: 0;
    font-family: "Times New Roman", serif;
    font-size: clamp(1.1rem, 1.35vw, 1.35rem);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .floating-file__preview-lines {
    display: grid;
    gap: 0.35rem;
    margin-top: 0.15rem;
  }
  .floating-file__preview-lines span {
    display: block;
    height: 1px;
    background: rgba(0, 0, 0, 0.32);
  }
  .floating-file__preview-lines span:nth-child(1) { width: 96%; }
  .floating-file__preview-lines span:nth-child(2) { width: 88%; }
  .floating-file__preview-lines span:nth-child(3) { width: 94%; }
  .floating-file__preview-lines span:nth-child(4) { width: 72%; }
  .floating-file__preview-lines span:nth-child(5) { width: 82%; }
  .floating-file__preview-mark {
    margin-top: auto;
    margin-bottom: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .floating-file__meta {
    border-top: 1px solid rgba(0, 0, 0, 0.35);
    padding: 0.45rem 0.5rem;
    display: flex;
    justify-content: space-between;
    gap: 0.45rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.94);
  }
  .floating-file__title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (hover: hover) and (pointer: fine) {
    .floating-file__sheet:hover {
      transform: translateY(-8px);
      box-shadow: 18px 20px 0 rgba(0, 0, 0, 0.34);
    }

    :global(html.dark) .floating-file__sheet:hover {
      box-shadow: 18px 20px 0 rgba(255, 255, 255, 0.3);
    }
  }

  :global(html.dark) .floating-file__sheet {
    background: #0d0d0d;
    border-color: rgba(255, 255, 255, 0.74);
    box-shadow: 14px 16px 0 rgba(255, 255, 255, 0.2);
  }
  :global(html.dark) .floating-file__preview {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
      repeating-linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.06) 0 1px,
        transparent 1px 26px
      ),
      #111;
  }
  :global(html.dark) .floating-file__preview-paper {
    border-color: rgba(255, 255, 255, 0.26);
    background: rgba(10, 10, 10, 0.9);
  }
  :global(html.dark) .floating-file__preview-lines span {
    background: rgba(255, 255, 255, 0.35);
  }
  :global(html.dark) .floating-file__meta {
    border-color: rgba(255, 255, 255, 0.32);
    background: rgba(15, 15, 15, 0.92);
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-file__sheet {
      transition: none;
    }
  }

  @media (max-width: 1200px) {
    .files-scene { grid-template-columns: repeat(2, minmax(0, 1fr)); min-height: auto; }
  }
  @media (max-width: 760px) {
    .files-scene {
      margin-inline: 0;
      width: 100%;
      grid-template-columns: 1fr;
      gap: 1.2rem;
      padding: 0.7rem 0 0;
    }
    .floating-file__sheet { width: min(100%, 360px); }
  }
</style>

<script>
  import { t } from "../utils/i18n";

  const KEYS = ["recommendation", "goit", "sedes", "tracto"];

  const updateAchievementsText = () => {
    const achievementItems = document.querySelectorAll(".floating-file");
    achievementItems.forEach((item, index) => {
      const title = item.querySelector(".floating-file__title");
      const previewTitle = item.querySelector(".floating-file__preview-title");
      if (title) title.textContent = t(`achievements.items.${KEYS[index]}.title`);
      if (previewTitle) previewTitle.textContent = t(`achievements.items.${KEYS[index]}.title`);
    });
  };

  window.addEventListener("storage", (e) => {
    if (e.key === "language") updateAchievementsText();
  });
  window.addEventListener("language-change", updateAchievementsText);

  document.addEventListener("astro:page-load", updateAchievementsText);
</script>
