---
import ThemeToggle from "./ThemeToggle.astro"
import LanguageToggle from "./LanguageToggle.astro"
import { t } from "../utils/i18n"
---

<header class="top-shell">
  <div class="top-shell__brand">
    <p id="brand-title" class="top-shell__title">{t("header.brand.es")}</p>
    <p id="brand-subtitle" class="top-shell__subtitle">{t("header.subtitle")}</p>
  </div>

  <div class="top-shell__controls" aria-label="Site controls">
    <div class="top-shell__control-item">
      <LanguageToggle />
    </div>
    <div class="top-shell__control-item">
      <ThemeToggle />
    </div>
  </div>
</header>

<script>
  import { t } from "../utils/i18n"
  const updateBrandTitle = () => {
    const brandTitle = document.getElementById("brand-title")
    const brandSubtitle = document.getElementById("brand-subtitle")
    const currentLanguage = localStorage.getItem("language") ?? "Español"
    if (!brandTitle) return
    brandTitle.textContent =
      currentLanguage === "English" ? t("header.brand.en") : t("header.brand.es")
    if (brandSubtitle) brandSubtitle.textContent = t("header.subtitle")
  }

  window.addEventListener("storage", (e) => {
    if (e.key === "language") {
      updateBrandTitle()
    }
  })
  window.addEventListener("language-change", updateBrandTitle)

  document.addEventListener("astro:page-load", () => {
    updateBrandTitle()
  })
</script>

<style>
  .top-shell {
    box-sizing: border-box;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    min-height: 93px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 24px 48px;
    background: #fff;
    border-bottom: 1px solid #000;
    color: #000;
  }

  :global(html.dark) .top-shell {
    background: #000;
    border-bottom: 1px solid #fff;
    color: #fff;
  }

  .top-shell__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    min-width: 0;
  }

  .top-shell__title {
    margin: 0;
    font-family: "Arial Black", "Inter", sans-serif;
    font-style: normal;
    font-weight: 900;
    font-size: clamp(1.35rem, 2.2vw, 1.875rem);
    line-height: 1;
    letter-spacing: -0.1em;
    color: #000;
    white-space: nowrap;
    transition: letter-spacing 280ms ease, opacity 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .top-shell__brand:hover .top-shell__title {
      letter-spacing: -0.12em;
    }
  }

  :global(html.dark) .top-shell__title {
    color: #fff;
  }

  .top-shell__subtitle {
    margin: 0;
    opacity: 0.6;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-style: normal;
    font-weight: 400;
    font-size: 9px;
    line-height: 14px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #1b1c1c;
    white-space: nowrap;
  }

  :global(html.dark) .top-shell__subtitle {
    color: rgba(255, 255, 255, 0.7);
  }

  .top-shell__controls {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    justify-content: flex-end;
  }

  .top-shell__control-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    color: #1b1c1c;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 10px;
    font-weight: 400;
    line-height: 15px;
    text-transform: uppercase;
  }

  :global(html.dark) .top-shell__control-item {
    color: #fff;
  }

  @media (max-width: 768px) {
    .top-shell {
      position: static;
      min-height: 93px;
      padding: 12px 16px;
      gap: 8px;
      align-items: center;
      flex-wrap: nowrap;
    }

    .top-shell__brand {
      width: auto;
      min-width: 0;
    }

    .top-shell__title {
      font-size: 20px;
    }

    .top-shell__subtitle {
      display: none;
    }

    .top-shell__controls {
      width: auto;
      justify-content: flex-end;
      gap: 8px;
      margin-left: auto;
    }
  }

  @media (max-width: 460px) {
    .top-shell__title {
      font-size: 17px;
      letter-spacing: -0.05em;
    }

    .top-shell {
      padding-inline: 12px;
      padding-top: 12px;
    }
  }
</style>
